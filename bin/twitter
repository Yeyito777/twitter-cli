#!/usr/bin/env python3
"""twitter — Terminal client for X/Twitter.

Mirrors the requests that the web client (x.com) makes, using auth tokens
extracted from a logged-in qutebrowser-mnemo session. From Twitter's servers'
perspective, this is indistinguishable from normal browser usage.

No API keys. No paid tiers.

Usage:
    twitter timeline            Home feed
    twitter search "query"      Search tweets
    twitter tweet <id_or_url>   View a single tweet
    twitter profile @user       View a user's profile
    twitter post "text"         Post a tweet
    twitter like <id_or_url>    Like a tweet
    twitter help [command]      Detailed help
"""

import sys
import os
import re

# Resolve symlinks so imports work from ~/.local/bin/twitter
PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, PROJECT_ROOT)

import argparse
import json

from lib.api import graphql_get, graphql_post, rest_get, rest_post
from lib.parse import parse_timeline_entries, parse_tweet
from lib.format import format_timeline, format_tweet, format_json


