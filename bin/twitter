# ─── CLI Setup ─────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        prog="twitter",
        description="Terminal client for X/Twitter.",
        add_help=True,
    )
    parser.add_argument(
        "--json", action="store_true",
        help="Output as JSON instead of human-readable text",
    )
    subparsers = parser.add_subparsers(dest="command")

    # help
    p = subparsers.add_parser("help", help="Show help for a command")
    p.add_argument("topic", nargs="*", help="Command to get help for")

    # timeline
    p = subparsers.add_parser("timeline", aliases=["tl"], help="Home timeline")
    p.add_argument("-n", "--count", type=int, default=20, help="Number of tweets")
    p.add_argument("-c", "--cursor", type=str, help="Pagination cursor")
    p.add_argument("-l", "--latest", action="store_true", help="Latest/chronological")

    # post
    p = subparsers.add_parser("post", help="Post a tweet")
    p.add_argument("text", nargs="+", help="Tweet text")
    p.add_argument("-r", "--reply", type=str, help="Tweet ID/URL to reply to")
    p.add_argument("-q", "--quote", type=str, help="Tweet ID/URL to quote")

    # reply (alias for post --reply)
    p = subparsers.add_parser("reply", help="Reply to a tweet")
    p.add_argument("tweet", help="Tweet ID or URL to reply to")
    p.add_argument("text", nargs="+", help="Reply text")

    # tweet (view)
    p = subparsers.add_parser("tweet", help="View a single tweet")
    p.add_argument("tweet", help="Tweet ID or URL")

    # search
    p = subparsers.add_parser("search", aliases=["s"], help="Search tweets")
    p.add_argument("query", nargs="+", help="Search query")
    p.add_argument("-n", "--count", type=int, default=20, help="Number of results")
    p.add_argument("-c", "--cursor", type=str, help="Pagination cursor")
    p.add_argument("-l", "--latest", action="store_true", help="Latest results")

    # profile
    p = subparsers.add_parser("profile", aliases=["p"], help="View user profile")
    p.add_argument("user", help="Username (with or without @)")

    # like / unlike
    p = subparsers.add_parser("like", help="Like a tweet")
    p.add_argument("tweet", help="Tweet ID or URL")
    p = subparsers.add_parser("unlike", help="Unlike a tweet")
    p.add_argument("tweet", help="Tweet ID or URL")

    # rt / unrt
    p = subparsers.add_parser("rt", help="Retweet")
    p.add_argument("tweet", help="Tweet ID or URL")
    p = subparsers.add_parser("unrt", help="Undo retweet")
    p.add_argument("tweet", help="Tweet ID or URL")

    # delete
    p = subparsers.add_parser("delete", help="Delete a tweet")
    p.add_argument("tweet", help="Tweet ID or URL")

    # bookmark / unbookmark
    p = subparsers.add_parser("bookmark", aliases=["bm"], help="Bookmark a tweet")
    p.add_argument("tweet", help="Tweet ID or URL")
    p = subparsers.add_parser("unbookmark", aliases=["ubm"], help="Remove bookmark")
    p.add_argument("tweet", help="Tweet ID or URL")

    # tweets (user's tweets)
    p = subparsers.add_parser("tweets", help="View a user's tweets")
    p.add_argument("user", help="Username (with or without @)")
    p.add_argument("-n", "--count", type=int, default=20, help="Number of tweets")
    p.add_argument("-c", "--cursor", type=str, help="Pagination cursor")
    p.add_argument("--replies", action="store_true", help="Include replies")

    # thread
    p = subparsers.add_parser("thread", help="View a full thread/conversation")
    p.add_argument("tweet", help="Tweet ID or URL (any tweet in the thread)")

    # notifications
    p = subparsers.add_parser("notifications", aliases=["notif"], help="Recent notifications")
    p.add_argument("-n", "--count", type=int, default=20, help="Number of notifications")
    p.add_argument("-c", "--cursor", type=str, help="Pagination cursor")

    # bookmarks (list)
    p = subparsers.add_parser("bookmarks", aliases=["bms"], help="List bookmarked tweets")
    p.add_argument("-n", "--count", type=int, default=20, help="Number of bookmarks")
    p.add_argument("-c", "--cursor", type=str, help="Pagination cursor")

    # trending
    p = subparsers.add_parser("trending", help="Trending topics")
    p.add_argument("-n", "--count", type=int, default=20, help="Number of trends")

    # dms (list conversations)
    p = subparsers.add_parser("dms", help="List DM conversations")

    # dm (read/send conversation)
    p = subparsers.add_parser("dm", help="Read or send a DM conversation")
    p.add_argument("conversation", help="Conversation ID or @username")
    p.add_argument("-s", "--send", nargs="+", help="Send a message")

    # follow / unfollow
    p = subparsers.add_parser("follow", help="Follow a user")
    p.add_argument("user", help="Username (with or without @)")
    p = subparsers.add_parser("unfollow", help="Unfollow a user")
    p.add_argument("user", help="Username (with or without @)")

    # mute / unmute
    p = subparsers.add_parser("mute", help="Mute a user")
    p.add_argument("user", help="Username (with or without @)")
    p = subparsers.add_parser("unmute", help="Unmute a user")
    p.add_argument("user", help="Username (with or without @)")

    # block / unblock
    p = subparsers.add_parser("block", help="Block a user")
    p.add_argument("user", help="Username (with or without @)")
    p = subparsers.add_parser("unblock", help="Unblock a user")
    p.add_argument("user", help="Username (with or without @)")

    args = parser.parse_args()

    if not args.command:
        cmd_help(argparse.Namespace(topic=[]))
        sys.exit(0)

    dispatch = {
        "help": cmd_help,
        "timeline": cmd_timeline, "tl": cmd_timeline,
        "post": cmd_post,
        "reply": cmd_reply,
        "tweet": cmd_tweet,
        "search": cmd_search, "s": cmd_search,
        "profile": cmd_profile, "p": cmd_profile,
        "tweets": cmd_tweets,
        "thread": cmd_thread,
        "notifications": cmd_notifications, "notif": cmd_notifications,
        "bookmarks": cmd_bookmarks, "bms": cmd_bookmarks,
        "trending": cmd_trending,
        "dms": cmd_dms,
        "dm": cmd_dm,
        "follow": cmd_follow, "unfollow": cmd_unfollow,
        "mute": cmd_mute, "unmute": cmd_unmute,
        "block": cmd_block, "unblock": cmd_unblock,
        "like": cmd_like, "unlike": cmd_unlike,
        "rt": cmd_rt, "unrt": cmd_unrt,
        "delete": cmd_delete,
        "bookmark": cmd_bookmark, "bm": cmd_bookmark,
        "unbookmark": cmd_unbookmark, "ubm": cmd_unbookmark,
    }

    try:
        dispatch[args.command](args)
    except RuntimeError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
