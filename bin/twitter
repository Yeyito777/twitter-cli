DM_PARAMS = {
    "nsfw_filtering_enabled": "false",
    "filter_low_quality": "false",
    "include_quality": "all",
    "include_profile_interstitial_type": "1",
    "include_blocking": "1",
    "include_blocked_by": "1",
    "include_followed_by": "1",
    "include_want_retweets": "1",
    "include_mute_edge": "1",
    "include_can_dm": "1",
    "include_ext_is_blue_verified": "1",
    "include_ext_verified_type": "1",
    "include_ext_profile_image_shape": "1",
}


def _format_dm_time(time_ms):
    """Convert DM timestamp (ms) to readable date."""
    try:
        from datetime import datetime, timezone
        dt = datetime.fromtimestamp(int(time_ms) / 1000, tz=timezone.utc)
        return dt.strftime("%Y-%m-%d %H:%M")
    except (ValueError, TypeError, OSError):
        return str(time_ms)


def cmd_dms(args):
    """List DM conversations."""
    data = rest_get("/1.1/dm/inbox_initial_state.json", DM_PARAMS)
    inbox = data.get("inbox_initial_state", {})
    users = inbox.get("users", {})
    convos = inbox.get("conversations", {})
    entries = inbox.get("entries", [])

    # Build user map
    user_map = {}
    for uid, u in users.items():
        user_map[uid] = {
            "name": u.get("name", uid),
            "handle": u.get("screen_name", uid),
        }

    # Build last message per conversation
    last_msg = {}
    for entry in entries:
        msg = entry.get("message", {})
        conv_id = msg.get("conversation_id", "")
        md = msg.get("message_data", {})
        time_ms = msg.get("time", "0")
        if conv_id not in last_msg or int(time_ms) > int(last_msg[conv_id]["time"]):
            last_msg[conv_id] = {
                "sender": md.get("sender_id", ""),
                "text": md.get("text", ""),
                "time": time_ms,
            }

    results = []
    for conv_id, conv in convos.items():
        participants = conv.get("participants", [])
        others = []
        for p in participants:
            uid = p["user_id"]
            if uid in user_map:
                others.append(user_map[uid])
        lm = last_msg.get(conv_id, {})
        results.append({
            "conversation_id": conv_id,
            "participants": others,
            "last_message": lm.get("text", ""),
            "last_sender": user_map.get(lm.get("sender", ""), {}).get("handle", "?"),
            "last_time": _format_dm_time(lm.get("time", "")),
            "type": conv.get("type", ""),
        })

    if args.json:
        print(format_json(results))
    else:
        if not results:
            print("No conversations found.")
        else:
            for r in results:
                names = " & ".join(
                    f"@{p['handle']} ({p['name']})" for p in r["participants"]
                )
                print(f"💬 {names}")
                print(f"   ID: {r['conversation_id']}")
                if r["last_message"]:
                    preview = r["last_message"][:100]
                    if len(r["last_message"]) > 100:
                        preview += "..."
                    print(f"   [{r['last_time']}] @{r['last_sender']}: {preview}")
                print()


def cmd_dm(args):
    """Read or send a DM in a conversation."""
    # If --send is provided, send a message
    if args.send:
        _dm_send(args)
        return

    # Otherwise, read the conversation
    conv_id = args.conversation

    # If a @username is given instead of a conversation ID, resolve it
    if not conv_id.replace("-", "").isdigit():
        user_id, _ = _resolve_user_id(conv_id)
        # Get own user ID from the inbox
        data = rest_get("/1.1/dm/inbox_initial_state.json", DM_PARAMS)
        inbox = data.get("inbox_initial_state", {})
        convos = inbox.get("conversations", {})
        # Find conversation with this user
        found = False
        for cid, conv in convos.items():
            pids = [p["user_id"] for p in conv.get("participants", [])]
            if user_id in pids:
                conv_id = cid
                found = True
                break
        if not found:
            print(f"No conversation found with @{args.conversation.lstrip('@')}",
                  file=sys.stderr)
            sys.exit(1)

    data = rest_get(f"/1.1/dm/conversation/{conv_id}.json", DM_PARAMS)
    conv = data.get("conversation_timeline", {})
    entries = conv.get("entries", [])
    users = conv.get("users", {})

    user_map = {}
    for uid, u in users.items():
        user_map[uid] = u.get("screen_name", uid)

    messages = []
    for entry in entries:
        msg = entry.get("message", {})
        md = msg.get("message_data", {})
        if not md:
            continue
        sender_id = md.get("sender_id", "")
        messages.append({
            "sender": user_map.get(sender_id, sender_id),
            "text": md.get("text", ""),
            "time": _format_dm_time(msg.get("time", "")),
            "id": entry.get("message", {}).get("id", ""),
        })

    if args.json:
        print(format_json(messages))
    else:
        if not messages:
            print("No messages in this conversation.")
        else:
            for m in messages:
                print(f"[{m['time']}] @{m['sender']}: {m['text']}")


def _dm_send(args):
    """Send a DM."""
    conv_id = args.conversation
    text = " ".join(args.send)

    # If a @username is given, resolve to conversation ID
    if not conv_id.replace("-", "").isdigit():
        user_id, _ = _resolve_user_id(conv_id)
        # Try to find existing conversation
        data = rest_get("/1.1/dm/inbox_initial_state.json", DM_PARAMS)
        inbox = data.get("inbox_initial_state", {})
        convos = inbox.get("conversations", {})
        found = False
        for cid, conv in convos.items():
            pids = [p["user_id"] for p in conv.get("participants", [])]
            if user_id in pids:
                conv_id = cid
                found = True
                break
        if not found:
            # New conversation — just use the recipient user ID
            conv_id = None

    payload = {
        "conversation_id": conv_id,
        "text": text,
        "cards_platform": "Web-12",
        "include_cards": 1,
        "include_quote_count": True,
        "dm_users": False,
    }
    if conv_id is None:
        # New conversation to a user
        payload.pop("conversation_id")
        payload["recipient_ids"] = False
        # Actually for new DMs we need recipient_ids
        payload = {
            "recipient_ids": [user_id],
            "text": text,
            "cards_platform": "Web-12",
            "include_cards": 1,
        }

    result = rest_post("/1.1/dm/new2.json", payload)

    if args.json:
        print(format_json(result))
    else:
        print(f"DM sent to conversation {conv_id or 'new'}")


def cmd_trending(args):
    """View trending topics."""
    # Step 1: fetch ExplorePage to get the trending timeline ID
    data = graphql_get(
        Q["ExplorePage"], "ExplorePage",
        {"count": 20, "includePromotedContent": False},
    )

    body = data.get("data", {}).get("explore_page", {}).get("body", {})
    timelines = body.get("timelines", [])

    trending_id = None
    for t in timelines:
        if t.get("id") == "trending":
            trending_id = t.get("timeline", {}).get("id")
            break

    if not trending_id:
        print("Could not find trending timeline.", file=sys.stderr)
        sys.exit(1)

    # Step 2: fetch the trending timeline
    data = graphql_get(
        Q["GenericTimelineById"], "GenericTimelineById",
        {
            "timelineId": trending_id,
            "count": args.count,
            "withQuickPromoteEligibilityTweetFields": True,
        },
    )

    instructions = (
        data.get("data", {})
        .get("timeline", {}).get("timeline", {})
        .get("instructions", [])
    )

    entries = []
    for inst in instructions:
        if inst.get("type") == "TimelineAddEntries":
            entries = inst.get("entries", [])
            break

    items, cursors = parse_timeline_entries(entries)

    if args.json:
        print(format_json(items))
    else:
        if not items:
            print("No trending topics found.")
        else:
            print(format_timeline(items, cursors))


def cmd_like(args):
    """Like a tweet."""
    tweet_id = _require_tweet_ref(args.tweet)
    graphql_post(Q["FavoriteTweet"], "FavoriteTweet", {"tweet_id": tweet_id})
    if args.json:
        print(format_json({"liked": tweet_id}))
    else:
        print(f"Liked tweet {tweet_id}")


def cmd_unlike(args):
    """Unlike a tweet."""
    tweet_id = _require_tweet_ref(args.tweet)
    graphql_post(Q["UnfavoriteTweet"], "UnfavoriteTweet", {"tweet_id": tweet_id})
    if args.json:
        print(format_json({"unliked": tweet_id}))
    else:
        print(f"Unliked tweet {tweet_id}")


def cmd_rt(args):
    """Retweet a tweet."""
    tweet_id = _require_tweet_ref(args.tweet)
    graphql_post(
        Q["CreateRetweet"], "CreateRetweet",
        {"tweet_id": tweet_id, "dark_request": False},
    )
    if args.json:
        print(format_json({"retweeted": tweet_id}))
    else:
        print(f"Retweeted {tweet_id}")


def cmd_unrt(args):
    """Undo a retweet."""
    tweet_id = _require_tweet_ref(args.tweet)
    graphql_post(
        Q["DeleteRetweet"], "DeleteRetweet",
        {"source_tweet_id": tweet_id, "dark_request": False},
    )
    if args.json:
        print(format_json({"unretweeted": tweet_id}))
    else:
        print(f"Unretweeted {tweet_id}")


def cmd_delete(args):
    """Delete one of your own tweets."""
    tweet_id = _require_tweet_ref(args.tweet)
    graphql_post(
        Q["DeleteTweet"], "DeleteTweet",
        {"tweet_id": tweet_id, "dark_request": False},
    )
    if args.json:
        print(format_json({"deleted": tweet_id}))
    else:
        print(f"Deleted tweet {tweet_id}")


def cmd_bookmark(args):
    """Bookmark a tweet."""
    tweet_id = _require_tweet_ref(args.tweet)
    graphql_post(Q["CreateBookmark"], "CreateBookmark", {"tweet_id": tweet_id})
    if args.json:
        print(format_json({"bookmarked": tweet_id}))
    else:
        print(f"Bookmarked tweet {tweet_id}")


def cmd_unbookmark(args):
    """Remove a bookmark from a tweet."""
    tweet_id = _require_tweet_ref(args.tweet)
    graphql_post(Q["DeleteBookmark"], "DeleteBookmark", {"tweet_id": tweet_id})
    if args.json:
        print(format_json({"unbookmarked": tweet_id}))
    else:
        print(f"Unbookmarked tweet {tweet_id}")


def _user_action(args, endpoint, action_name, past_tense):
    """Perform a user-targeted REST action (follow, mute, block, etc.)."""
    username = args.user.lstrip("@")
    user_id, _ = _resolve_user_id(username)
    rest_post(endpoint, {"user_id": user_id}, form=True)
    if args.json:
        print(format_json({action_name: username, "user_id": user_id}))
    else:
        print(f"{past_tense} @{username}")


def cmd_follow(args):
    """Follow a user."""
    _user_action(args, "/1.1/friendships/create.json", "followed", "Followed")


def cmd_unfollow(args):
    """Unfollow a user."""
    _user_action(args, "/1.1/friendships/destroy.json", "unfollowed", "Unfollowed")


def cmd_mute(args):
    """Mute a user."""
    _user_action(args, "/1.1/mutes/users/create.json", "muted", "Muted")


def cmd_unmute(args):
    """Unmute a user."""
    _user_action(args, "/1.1/mutes/users/destroy.json", "unmuted", "Unmuted")


def cmd_block(args):
    """Block a user."""
    _user_action(args, "/1.1/blocks/create.json", "blocked", "Blocked")


def cmd_unblock(args):
    """Unblock a user."""
    _user_action(args, "/1.1/blocks/destroy.json", "unblocked", "Unblocked")


def cmd_help(args):
    """Show detailed help for the twitter tool or a specific command."""
    if not args.topic:
        # General help
        print(HELP_TEXT)
        return

    topic = args.topic[0]

    if topic in COMMAND_HELP:
        info = COMMAND_HELP[topic]
        print(f"\ntwitter {topic}" + (f" (alias: {info['alias']})" if info.get("alias") else ""))
        print(f"  {info['summary']}\n")
        print(f"  Usage: {info['usage']}\n")
        if info.get("flags"):
            print("  Flags:")
            for flag, desc in info["flags"].items():
                print(f"    {flag:20s} {desc}")
            print()
        if info.get("examples"):
            print("  Examples:")
            for ex in info["examples"]:
                print(f"    {ex}")
            print()
    else:
        # Check if it's an alias
        for cmd, info in COMMAND_HELP.items():
            if info.get("alias") == topic:
                args.topic = [cmd]
                cmd_help(args)
                return
        print(f"Unknown command: {topic}")
        print(f"Run 'twitter help' for available commands.")


# ─── Help Content ──────────────────────────────────────────

HELP_TEXT = """\
twitter — Terminal client for X/Twitter

Works by mirroring the requests that x.com's web client makes, using auth
tokens from a logged-in qutebrowser-mnemo session. Indistinguishable from
normal browser usage. No API keys, no paid tiers.

Commands:
  Reading:
    timeline, tl         Home feed (algorithmic or --latest chronological)
    tweet <id_or_url>    View a single tweet by ID or URL
    search, s <query>    Search tweets (--latest for chronological)
    profile, p <@user>   View a user's profile (bio, stats, verified)
    tweets <@user>       View a user's tweets (--replies to include replies)
    thread <id_or_url>   View a full thread/conversation around a tweet
    notifications, notif Recent notifications (mentions, likes, RTs, follows)
    bookmarks, bms       List your bookmarked tweets
    trending             Trending topics worldwide

  Direct Messages:
    dms                  List all DM conversations with last message
    dm <@user_or_id>     Read a DM conversation
    dm <@user> -s <text> Send a DM

  Posting:
    post <text>          Post a tweet
    reply <tweet> <text> Reply to a tweet
    post -r <tweet> <text>   Reply to a tweet (alternative)
    post -q <tweet> <text>   Quote tweet
    delete <id_or_url>   Delete one of your own tweets

  Engagement:
    like / unlike        Like or unlike a tweet
    rt / unrt            Retweet or undo a retweet
    bookmark, bm         Bookmark a tweet
    unbookmark, ubm      Remove a bookmark
    follow / unfollow    Follow or unfollow a user
    mute / unmute        Mute or unmute a user
    block / unblock      Block or unblock a user

  Other:
    help [command]       Show this help, or help for a specific command

Global flags:
  --json                 Output as JSON (works on all commands)

Tweet references:
  Anywhere a tweet is needed, pass a full URL or a bare numeric ID:
    https://x.com/user/status/1234567890
    1234567890

User references:
  Anywhere a user is needed, pass with or without @:
    @im_aurelio
    im_aurelio

Run 'twitter help <command>' for detailed help on any command.\
"""

